# Folder in container that contains configs for raiko
RAIKO_CONF_DIR=/raiko/config/devnet/

# Config file from RAIKO_CONF_DIR folder to use
BASE_CONFIG_FILE=config.json

# Chain spec list file from RAIKO_CONF_DIR folder to use
BASE_CHAINSPEC_FILE=chain_spec_list.json


### SP1 ENV SETTINGS

# Could be mock, local, network
SP1_PROVER=local

# Address of succint prover contract (NOTE: succint's verifyer contract, not surge's)
SP1_VERIFIER_ADDRESS=""

# RPC URL where the succint prover contract is deployed (should be L1)
SP1_VERIFIER_RPC_URL=""


### RISC0 ENV SETTINGS

# RPC for GROTH16 risc0 verifier (NOTE: it's risc0's groth16 verifyer contract, not surge's)
GROTH16_VERIFIER_RPC_URL=""

GROTH16_VERIFIER_ADDRESS=""

# Url for Bonsai (Bento) api
BONSAI_API_URL=http://0.0.0.0:8081

# API key for Bonsai (Bento), you could leave it blank
BONSAI_API_KEY=


# Redis URL for caching
REDIS_URL=redis://redis:6379

# Rust log level
RUST_LOG=info

# Mock key (ecdsa private key) for testing, should be left empty for real proving
# If set, it will be used mock proving regardless of prover type. 
# MOCK_KEY=


# Set specific GPU devices to use (comma separated), leave empty to use all available devices
#CUDA_VISIBLE_DEVICES=0,1,2,3


### SURGE PRIVACY MODE
#
# Off by default. The runtime image (surge-raiko-zk) is published by CI with
# *empty* SURGE_PRIVACY_*_HASH baked into the guest, so privacy is a no-op
# unless you explicitly opt in here.
#
# Architecture: only the guest ELFs need to bake the hashes in at compile
# time (`option_env!()` in `lib::utils::realtime`). The host doesn't — it
# reads the runtime keys below and forwards them to the guest as witness.
# So enabling privacy rotates the guest only, not the host image — turning
# a 5-minute CUDA cargo build into a ~30 second guest compile.
#
# Two-VM workflow (recommended), enabling privacy:
#   1. (L2 VM, in simple-surge-node)
#        ./script/sync-privacy-to-prover.sh --rebuild user@<prover-host>
#      That command scp's the four lines below into this file, then runs
#      step 2 + step 3 over SSH automatically.
#   2. (Prover VM) build guest ELFs with the new hashes:
#        ./script/build-guest-with-hashes.sh
#      Drops zisk-batch / zisk-aggregation / zisk-shasta-aggregation into
#      docker/guest-elfs/ — bind-mounted by docker-compose-zk.yml over the
#      image's defaults.
#   3. (Prover VM) restart the runtime so the new ELFs are picked up:
#        docker compose -f docker/docker-compose-zk.yml up -d --force-recreate raiko-zk
#
# Disabling privacy: set SURGE_PRIVACY_MODE=false, clear the four lines below,
# rerun ./script/build-guest-with-hashes.sh (auto-falls back to extracting the
# default ELFs out of the runtime image — no cargo build), then recreate
# raiko-zk. The host's runtime privacy check is short-circuited when the
# symmetric key is empty.

SURGE_PRIVACY_MODE=false

# Runtime keys (host decrypts blobs with these — keep secret):
SURGE_PRIVACY_SYMMETRIC_KEY=
SURGE_PRIVACY_FI_PRIVKEY=

# Build-time hashes (guest verifies keccak256(runtime_key) == this hash):
SURGE_PRIVACY_SYMMETRIC_KEY_HASH=
SURGE_PRIVACY_FI_PRIVKEY_HASH=
